# =============================================
# 3LMTO - Environment Variables (.env)
# =============================================

# --- Supabase (Required) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Paymob (Required for Payments) ---
PAYMOB_API_KEY=your-paymob-api-key
PAYMOB_INTEGRATION_ID=your-paymob-integration-id
PAYMOB_IFRAME_ID=your-paymob-iframe-id
PAYMOB_HMAC_SECRET=your-paymob-hmac-secret

# --- Bunny.net (Required for Video) ---
NEXT_PUBLIC_BUNNY_LIBRARY_ID=your-bunny-library-id
BUNNY_LIBRARY_ID=your-bunny-library-id
BUNNY_API_KEY=your-bunny-api-key

# --- App URL (Required) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
